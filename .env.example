# MySQL
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=

DEBUG=false

# 외부 API (값은 각 서비스 대시보드에서 발급)
SERP_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# BL-BE-50: Responses API 전용 (gpt-4.1-mini | gpt-5-mini)
OPENAI_RESPONSES_MODEL=gpt-4.1-mini
# BL-BE-51: 종목 추천 이유 문장 (gpt-5-mini | gpt-4.1-mini)
OPENAI_RECOMMENDATION_REASON_MODEL=gpt-5-mini

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
# 프론트엔드 주소 (로컬: http://localhost:3000, 모바일 테스트: http://<서버IP>:3000)
CORS_ALLOWED_FRONTEND_URL=http://localhost:3000
FRONTEND_AUTH_CALLBACK_URL=http://localhost:3000/auth-callback

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 세션/서명 (프로덕션에서는 강한 랜덤 문자열 사용)
AUTH_SECRET=
# 선택. 미설정 시 빈 문자열
AUTH_PASSWORD=

# 공시·시세·뉴스 등
DART_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
DATA_GO_KR_SERVICE_KEY=

# 네이버 OAuth (해당 기능 사용 시)
NAVER_CLIENT_ID=
NAVER_SECRET=

# Twitter/X 수집 (twitter_collector_adapter 사용 시)
TWITTER_BEARER_TOKEN=

# BL-BE-15: 히트맵 일봉 캐시를 Redis에 저장. false면 인메모리만.
HEATMAP_REDIS_CACHE_ENABLED=true
